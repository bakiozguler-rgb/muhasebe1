{
  "name": "muhasebe",
  "version": "1.0.0",
  "private": true,
  "author": "Baki",
  "description": "Kişisel muhasebe uygulaması",
  "main": "public/electron.js",
  "homepage": "./",
  "dependencies": {
    "electron-context-menu": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^2.0.0",
    "react-scripts": "5.0.1",
    "wait-on": "^9.0.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "wait-on tcp:3000 && electron .",
    "dev": "concurrently \"npm start\" \"npm run electron\"",
    "postbuild": "electron-builder -c.extraMetadata.main=build/electron.js",
    "build-exe": "npm run build && npm run postbuild",
    "build-win": "set DEBUG=electron-builder && electron-builder --win nsis -c.extraMetadata.main=build/electron.js"
  },
  "build": {
    "appId": "com.baki.muhasebe",
    "productName": "Kişisel Muhasebe",
    "electronVersion": "34.2.0",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/ikon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/ikon.ico",
      "uninstallerIcon": "public/ikon.ico"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}